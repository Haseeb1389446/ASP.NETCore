@{
}
@model List<Student>

<div class="container">
    <div class="row">
        <div class="col-md-2"></div>
        <div class="col-md-8">

            <h1 class="mt-5 mb-5">Show student</h1>
            <table class="table">
                <thead>
                    <tr>
                        <th scope="col">ID</th>
                        <th scope="col">Name</th>
                        <th scope="col">Email</th>
                        <th scope="col">Class</th>
                        <th scope="col">Image</th>
                        <th scope="col">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var student in Model)
                    {
                    <tr>
                        <th scope="row">@student.Id</th>
                        <td>@student.Name</td>
                        <td>@student.Email</td>
                        <td>@student.Class</td>
                        <td><img height="50px" width="50px" src="~/images/@student.Image" alt="Image" /></td>
                        <td><a class="btn btn-warning" asp-controller="Home" asp-action="Update" asp-route-id="@student.Id">Edit</a> <a class="btn btn-danger" asp-controller="Home" asp-action="Delete" asp-route-id="@student.Id" onclick="return alert('User has been deleted Successfully.')">Delete</a></td>
                    </tr>    
                    }
                </tbody>
            </table>

        </div>
        <div class="col-md-2"></div>
    </div>
</div>